{
	"$schema": "../../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default capabilities for Hubble iOS",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"fs:default",
		"fs:allow-read-file",
		"fs:allow-write-file",
		"fs:allow-exists",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-rename",
		"fs:allow-read-dir",
		"shell:default",
		"shell:allow-open"
	]
}
