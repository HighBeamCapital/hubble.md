{
	"name": "@hubble.md/app-core",
	"version": "0.0.1",
	"description": "Shared state, actions, and utilities for Hubble.md apps",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@hubble.md/convex-client": "workspace:*",
		"@hubble.md/editor": "workspace:*",
		"@hubble.md/sync": "workspace:*",
		"@hubble.md/sync-backend": "workspace:*",
		"@simplestack/store": "^0.7.5",
		"convex": "^1.21.0"
	},
	"devDependencies": {
		"typescript": "~5.8.3"
	}
}
